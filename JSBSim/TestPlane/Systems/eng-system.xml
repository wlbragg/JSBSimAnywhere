<?xml version="1.0"?>
<system name="eng-system">

  <channel name="engine">

    <!-- Starter -->
    <switch name="starter">
      <input>fdm/jsbsim/propulsion/engine[0]/starter_cmd</input>
      <output>engines/engine[0]/starter</output>
    </switch>

    <!-- Magnetos -->
    <switch name="magnetos">
      <input>fdm/jsbsim/propulsion/magnetos_cmd</input>
      <output>engines/engine[0]/magnetos</output>
    </switch>

    <!-- Throttle -->
    <gain name="throttle">
      <input>fdm/jsbsim/propulsion/engine[0]/throttle-cmd-norm</input>
      <output>engines/engine[0]/throttle</output>
      <gain>1.0</gain>
    </gain>

    <!-- Mixture -->
    <gain name="mixture">
      <input>fdm/jsbsim/propulsion/engine[0]/mixture-cmd-norm</input>
      <output>engines/engine[0]/mixture</output>
      <gain>1.0</gain>
    </gain>

  </channel>

</system>
